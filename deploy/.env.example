# 幹事ちゃん (Kanji-Chan) 本番デプロイ用環境変数設定ファイル

# OAuth 認証設定 (Google または GitHub OAuth 2.0)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# Cookie セッション署名用シークレットキー (ランダムな長い文字列を設定してください)
# 生成例: openssl rand -base64 32
SESSION_SECRET=change-this-to-a-secure-random-secret-key-in-production

# 公開サイトURL (末尾スラッシュなし。SEO / OGP / robots.txt 等の生成に使用)
PUBLIC_SITE_URL=https://kanji.example.com

# (任意) Gemini API キー (個別設定がないユーザー向けの共有フォールバック用)
# GEMINI_API_KEY=AIzaSy...
