# 幹事ちゃん (Kanji-Chan) 本番デプロイ用環境変数設定ファイル

# サーバー公開ポート設定 (デフォルト: 8080)
PORT=8080

# データベース設定
DB_TYPE=sqlite
DB_PATH=/data/kanji.db

# OAuth 認証設定 (google または github)
OAUTH_PROVIDER=google
OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=https://kanji.example.com/api/auth/callback

# Cookie セッション署名用シークレットキー (ランダムな長い文字列を設定してください)
# 生成例: openssl rand -base64 32
SESSION_SECRET=change-this-to-a-secure-random-secret-key-in-production

# 公開サイトURL (末尾スラッシュなし。SEO / OGP / robots.txt 等の生成に使用)
PUBLIC_SITE_URL=https://kanji.example.com

# (任意) Gemini API キー (個別設定がないユーザー向けの共有フォールバック用)
# GEMINI_API_KEY=AIzaSy...
