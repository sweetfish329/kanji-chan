# 幹事ちゃん (Kanji-Chan) 環境変数設定サンプル

# OAuth設定 (google または github)
OAUTH_PROVIDER=google
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret
OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/callback

# セッション管理用シークレットキー
SESSION_SECRET=super-secret-key-change-me-in-production

# AI (Gemini) APIキー (フォールバック用。ユーザーが画面から個別登録しない場合のデフォルト)
GEMINI_API_KEY=your-gemini-api-key

# データベース設定 (sqlite または postgres)
DB_TYPE=sqlite
DB_PATH=kanji.db

# ==========================================
# サイトURL設定 (SEO用)
# デプロイ時に実際のドメインを設定してください
# ==========================================

# バックエンド用: robots.txt / sitemap.xml の URL 生成に使用
# 末尾スラッシュなし
PUBLIC_SITE_URL=https://your-domain.example.com

# フロントエンド用 (Vite): canonical URL / OGP / JSON-LD に使用
# bun run build 時に読み込まれる。末尾スラッシュなし
VITE_PUBLIC_SITE_URL=https://your-domain.example.com
